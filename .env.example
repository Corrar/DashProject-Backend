# ── Núcleo ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787

# Neon (inclua ?sslmode=require na string). PG_SSL=false só p/ Postgres local sem TLS.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
PG_SSL=true

# URL do frontend (Vercel) — usada em links de e-mail e nos callbacks do checkout Asaas.
APP_URL=https://seu-frontend.vercel.app
# URL pública desta API (Render) — informativo.
API_URL=https://dash-backend.onrender.com
# Origens permitidas no CORS (exatas, separadas por vírgula — NÃO use *). Inclua a do frontend.
CORS_ORIGIN=https://seu-frontend.vercel.app,http://localhost:5173

# ── Auth (JWT próprio) ───────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=troque-por-um-segredo-forte
ACCESS_TTL_SECONDS=900          # 15 min
REFRESH_TTL_SECONDS=2592000     # 30 dias
REFRESH_COOKIE_NAME=dash_rt
COOKIE_DOMAIN=                  # vazio = host-only (recomendado p/ Render)

# ── E-mail (Resend — Render free bloqueia SMTP) ──────────────────────────
RESEND_API_KEY=                 # vazio = modo dev (link sai no log)
EMAIL_FROM=Dash <onboarding@resend.dev>

# ── Asaas (pagamentos) ───────────────────────────────────────────────────
# Os VALORES dos planos vêm de src/plans.ts (não de env). Aqui só credenciais.
ASAAS_API_KEY=                   # API key do Asaas (Configurações > Integrações)
ASAAS_ENV=sandbox                # sandbox | production
# Token de autenticação do webhook (você define no painel do Asaas e repete aqui).
# O Asaas o envia no header da requisição de webhook; o backend compara com este valor.
ASAAS_WEBHOOK_TOKEN=

# ── Gemini (ferramenta paga) ─────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
