# .env.example — modelo de configuração do backend Dash.
# Copie para .env e preencha com valores REAIS (o .env nunca é commitado).
# NENHUM valor real deve ser commitado aqui — só nomes e placeholders genéricos.

# ── Núcleo ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8787

# ── Banco (Neon) — obrigatório ───────────────────────────────────────────
# Inclua ?sslmode=require. PG_SSL=false só p/ Postgres local sem TLS.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
PG_SSL=true

# ── URLs / CORS ──────────────────────────────────────────────────────────
# APP_URL é OBRIGATÓRIO (links de e-mail + callbacks do checkout Asaas; precisa ser HTTPS público).
APP_URL=https://seu-frontend.vercel.app
API_URL=https://sua-api.onrender.com
# Origens permitidas (exatas, separadas por vírgula — NÃO use *).
CORS_ORIGIN=https://seu-frontend.vercel.app

# ── Auth (JWT próprio) — obrigatório ─────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
ACCESS_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
REFRESH_COOKIE_NAME=dash_rt
COOKIE_DOMAIN=

# ── E-mail (Resend) — opcional (sem a chave, links saem no log em dev) ────
RESEND_API_KEY=
EMAIL_FROM=Dash <onboarding@resend.dev>

# ── Asaas (pagamentos) ───────────────────────────────────────────────────
# Valores dos planos vêm de src/plans.ts (não de env). Aqui só credenciais.
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# ── Job de cobrança (cron externo /jobs/billing-tick) ────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
JOBS_SECRET=
RENEWAL_LEAD_DAYS=5
GRACE_DAYS=3

# ── Gemini (ferramenta paga de IA) ───────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
